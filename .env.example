JWT_SECRET="replace_me_with_a_long_random_secret"
JWT_EXPIRES_IN="30d"

## Daraja / M-Pesa (STK Push)
# DARAJA_CONSUMER_KEY=""
# DARAJA_CONSUMER_SECRET=""
# DARAJA_ENV="sandbox" # or "production"
# DARAJA_BASE_URL="" # optional override
# DARAJA_SHORTCODE=""
# DARAJA_PASSKEY=""
# DARAJA_CALLBACK_URL="https://your-domain.com/api/mpesa/callback?token=replace_me"
# DARAJA_CALLBACK_TOKEN="replace_me"
# DARAJA_TRANSACTION_TYPE="CustomerPayBillOnline" # or CustomerBuyGoodsOnline
# MPESA_INITIATOR_NAME=""
# MPESA_INITIATOR_PASSWORD=""

## Notifications (optional - for future web push/email/SMS integrations)
