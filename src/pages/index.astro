---
import BaseLayout from '@/layouts/BaseLayout.astro'
---

<BaseLayout title="Bossie Ride | Request rides 24/7" description="Request a ride for now or later with Bossie Ride.">
  <div class="marketing-light min-h-dvh bg-background text-foreground">
    <!-- Updated Top navigation with mobile menu -->
    <header class="sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur supports-[backdrop-filter]:bg-background/70">
      <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4">
        <!-- Logo -->
        <a href="./ride-request" class="flex items-center gap-2 font-semibold tracking-tight z-50">
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-black text-white">B</span>
          <span class="text-base sm:text-lg">Bossie Ride</span>
        </a>

        <!-- Desktop navigation + auth (visible from md upwards) -->
        <div class="hidden md:flex md:items-center md:gap-8">
          <nav class="flex items-center gap-6 text-sm font-medium" aria-label="Primary navigation">
            <a class="hover:underline underline-offset-4 transition-colors" href="./ride-request">Ride</a>
            <a class="hover:underline underline-offset-4 transition-colors" href="./placeholder">Drive</a>
            <a class="hover:underline underline-offset-4 transition-colors" href="./placeholder">Business</a>
            <a class="hover:underline underline-offset-4 transition-colors" href="./placeholder">Help</a>
          </nav>

          <div class="flex items-center gap-3 ml-8">
            <a 
              href="./login" 
              class="hidden sm:inline-flex rounded-full px-4 py-2 text-sm font-medium hover:bg-muted transition-colors"
            >
              Sign in
            </a>
            <a 
              href="./login" 
              class="inline-flex rounded-full bg-black px-5 py-2.5 text-sm font-semibold text-white hover:bg-black/90 transition-colors"
            >
              Sign up
            </a>
          </div>
        </div>

        <!-- Mobile menu toggle (visible below md) -->
        <div class="md:hidden z-50">
          <input type="checkbox" id="mobile-menu" class="peer hidden" />
          
          <label for="mobile-menu" class="cursor-pointer block">
            <div class="relative flex h-10 w-10 items-center justify-center">
              <!-- Hamburger lines -->
              <div class="relative h-0.5 w-7 rounded-full bg-foreground transition-all duration-300 peer-checked:bg-transparent">
                <span class="absolute left-0 top-[-0.375rem] h-0.5 w-7 rounded-full bg-foreground transition-all duration-300 ease-out peer-checked:top-0 peer-checked:rotate-45"></span>
                <span class="absolute left-0 bottom-[-0.375rem] h-0.5 w-7 rounded-full bg-foreground transition-all duration-300 ease-out peer-checked:bottom-0 peer-checked:-rotate-45"></span>
              </div>
            </div>
          </label>

          <!-- Mobile menu overlay + panel -->
          <div class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm transition-opacity duration-300 peer-checked:opacity-100 opacity-0 pointer-events-none peer-checked:pointer-events-auto md:hidden">
            <div class="absolute right-0 top-0 h-full w-4/5 max-w-sm bg-background shadow-2xl transition-transform duration-400 ease-in-out translate-x-full peer-checked:translate-x-0">
              <div class="flex flex-col h-full p-6 pt-20">
                <!-- Close button (X) -->
                <label 
                  for="mobile-menu" 
                  class="absolute right-6 top-6 text-2xl font-bold text-muted-foreground hover:text-foreground cursor-pointer transition-colors"
                >
                  ×
                </label>

                <!-- Mobile nav links -->
                <nav class="flex flex-col gap-6 text-lg font-medium mt-4">
                  <a href="./ride-request" class="hover:text-primary transition-colors">Ride</a>
                  <a href="./placeholder" class="hover:text-primary transition-colors">Drive</a>
                  <a href="./placeholder" class="hover:text-primary transition-colors">Business</a>
                  <a href="./placeholder" class="hover:text-primary transition-colors">Help</a>
                </nav>

                <!-- Auth buttons in mobile menu -->
                <div class="mt-10 flex flex-col gap-4 pt-8 border-t border-border">
                  <a 
                    href="./login" 
                    class="rounded-xl border border-border px-6 py-3.5 text-center font-medium hover:bg-muted transition-colors"
                  >
                    Sign in
                  </a>
                  <a 
                    href="./login" 
                    class="rounded-xl bg-black px-6 py-3.5 text-center font-semibold text-white hover:bg-black/90 transition-colors"
                  >
                    Sign up
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>
    <main>
      <!-- Hero -->
      <section class="mx-auto grid max-w-6xl gap-10 px-4 py-10 lg:grid-cols-2 lg:items-center lg:py-14">
        <div class="space-y-5">
          <h1 class="text-4xl font-semibold leading-tight tracking-tight sm:text-5xl">
            Request a ride for now or later
          </h1>
          <p class="max-w-prose text-base text-muted-foreground sm:text-lg">
            Add your trip details, hop in, and go. Fast pickup, clear pricing, and reliable support.
          </p>
          <form class="mt-6 rounded-2xl border border-border bg-card p-5 shadow-soft sm:p-6" action="./ride-request">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <label class="text-sm font-medium" for="pickup-when">Pickup time</label>
              <select
                id="pickup-when"
                name="when"
                class="h-10 rounded-full border border-input bg-background px-4 text-sm focus:outline-none focus:ring-2 focus:ring-ring"
              >
                <option value="now" selected>Pickup now</option>
                <option value="later">Pickup later</option>
              </select>
            </div>
            <div class="mt-4 space-y-3">
              <div>
                <label class="sr-only" for="pickup">Pickup location</label>
                <input
                  id="pickup"
                  name="pickup"
                  placeholder="Pickup location"
                  class="h-12 w-full rounded-xl border border-input bg-background px-4 text-sm outline-none focus:ring-2 focus:ring-ring"
                />
              </div>
              <div>
                <label class="sr-only" for="dropoff">Dropoff location</label>
                <input
                  id="dropoff"
                  name="dropoff"
                  placeholder="Dropoff location"
                  class="h-12 w-full rounded-xl border border-input bg-background px-4 text-sm outline-none focus:ring-2 focus:ring-ring"
                />
              </div>
            </div>
            <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-center">
              <button
                type="submit"
                class="inline-flex h-12 items-center justify-center rounded-xl bg-black px-5 text-sm font-semibold text-white hover:bg-black/90"
              >
                See prices
              </button>
              <a href="./login" class="text-sm font-medium hover:underline underline-offset-4">
                Sign up to ride
              </a>
            </div>
            <p class="mt-4 text-xs text-muted-foreground">
              Certain requirements and features vary by region. Availability depends on your location.
            </p>
          </form>
        </div>
        <!-- Right-side visual -->
        <div class="relative">
          <div class="aspect-[4/3] w-full overflow-hidden rounded-3xl border border-border bg-gradient-radial-at-t from-black/10 via-transparent to-transparent p-6">
            <div class="flex h-full flex-col justify-between">
              <div class="flex items-start justify-between gap-3">
                <div class="rounded-2xl border border-border bg-background/80 p-4 shadow-soft">
                  <p class="text-sm font-semibold">Your ride, your way</p>
                  <p class="mt-1 text-sm text-muted-foreground">Comfort, economy, or premium.</p>
                </div>
                <div class="rounded-2xl border border-border bg-background/80 p-4 shadow-soft">
                  <p class="text-sm font-semibold">700+ airports</p>
                  <p class="mt-1 text-sm text-muted-foreground">Schedule pickups in advance.</p>
                </div>
              </div>
              <div class="grid gap-3 sm:grid-cols-2">
                <div class="rounded-2xl border border-border bg-background/80 p-4 shadow-soft">
                  <p class="text-sm font-semibold">Upfront pricing</p>
                  <p class="mt-1 text-sm text-muted-foreground">Know your fare before you go.</p>
                </div>
                <div class="rounded-2xl border border-border bg-background/80 p-4 shadow-soft">
                  <p class="text-sm font-semibold">Safety tools</p>
                  <p class="mt-1 text-sm text-muted-foreground">Trip sharing and support.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="pointer-events-none absolute -bottom-6 -right-6 hidden h-32 w-32 rounded-full bg-black/5 blur-2xl lg:block"></div>
        </div>
      </section>

      <!-- App callout -->
      <section class="border-t border-border bg-muted/40">
        <div class="mx-auto grid max-w-6xl gap-6 px-4 py-10 md:grid-cols-2 md:items-center">
          <div class="space-y-2">
            <h2 class="text-2xl font-semibold tracking-tight sm:text-3xl">Do more in the app</h2>
            <p class="text-sm text-muted-foreground sm:text-base">
              Save places, view ride history, manage payments, and get support—right from your phone.
            </p>
          </div>
          <div class="flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:justify-end">
            <div class="hidden items-center gap-3 rounded-2xl border border-border bg-background p-3 shadow-soft sm:flex">
              <div class="grid h-14 w-14 grid-cols-7 gap-[2px] rounded-lg bg-black p-2">
                {Array.from({ length: 49 }).map((_, i) => (
                  <span
                    class:list={[
                      'block h-full w-full rounded-[1px]',
                      i % 3 === 0 || i % 5 === 0 ? 'bg-white' : 'bg-black',
                    ]}
                  />
                ))}
              </div>
              <div class="leading-tight">
                <p class="text-sm font-semibold">Scan to download</p>
                <p class="text-xs text-muted-foreground">Get the Bossie Ride app</p>
              </div>
            </div>
            <a
              href="./placeholder"
              class="inline-flex h-11 items-center justify-center rounded-xl bg-black px-5 text-sm font-semibold text-white hover:bg-black/90"
            >
              Download the app
            </a>
          </div>
        </div>
      </section>

      <!-- ... rest of your sections (Suggestions, Value props, Business, FAQ, footer) remain exactly the same ... -->

    </main>

    <footer class="border-t border-border">
      <div class="mx-auto flex max-w-6xl flex-col gap-3 px-4 py-8 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm text-muted-foreground">© {new Date().getFullYear()} Bossie Ride</p>
        <div class="flex flex-wrap gap-4 text-sm">
          <a class="text-muted-foreground hover:text-foreground hover:underline underline-offset-4" href="./placeholder">Privacy</a>
          <a class="text-muted-foreground hover:text-foreground hover:underline underline-offset-4" href="./placeholder">Terms</a>
          <a class="text-muted-foreground hover:text-foreground hover:underline underline-offset-4" href="./placeholder">Help</a>
        </div>
      </div>
    </footer>
  </div>
</BaseLayout