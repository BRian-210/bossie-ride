---
import { useState } from 'react'; // Not needed - we'll use vanilla JS with types

const title = "Bossie Ride - Get There Fast";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{title}</title>
  
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap');

    :root {
      --bg: #0a0a0a;
      --text: #ffffff;
      --accent: #00ff9d;
    }

    [data-theme="light"] {
      --bg: #f8f9fa;
      --text: #1a1a1a;
      --accent: #00cc7a;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      overflow: hidden;
      position: relative;
      transition: background 0.6s ease;
    }

    /* Animated Background */
    .background {
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, #1a0033, #000000);
      z-index: -2;
    }

    .background::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 20%, rgba(0, 255, 157, 0.15), transparent 50%),
                  radial-gradient(circle at 70% 80%, rgba(0, 255, 157, 0.12), transparent 50%);
      animation: pulse 15s infinite alternate ease-in-out;
    }

    @keyframes pulse {
      0% { opacity: 0.6; transform: scale(1); }
      100% { opacity: 1; transform: scale(1.08); }
    }

    /* Moving road lines */
    .road {
      position: absolute;
      bottom: 0;
      width: 100%;
      height: 40%;
      background: repeating-linear-gradient(
        90deg,
        transparent,
        transparent 40px,
        rgba(0, 255, 157, 0.2) 40px,
        rgba(0, 255, 157, 0.2) 60px
      );
      animation: roadMove 4s linear infinite;
    }

    @keyframes roadMove {
      0% { background-position: 0 0; }
      100% { background-position: -200px 0; }
    }

    .container {
      height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      position: relative;
      z-index: 2;
    }

    .content {
      max-width: 700px;
      padding: 2rem;
    }

    .logo {
      font-size: 4.8rem;
      font-weight: 700;
      letter-spacing: -3px;
      margin-bottom: 1rem;
      background: linear-gradient(90deg, #fff, var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      text-shadow: 0 0 40px rgba(0, 255, 157, 0.5);
    }

    .tagline {
      font-size: 1.7rem;
      margin-bottom: 3rem;
      opacity: 0.9;
      font-weight: 400;
      line-height: 1.3;
    }

    .cta-button {
      padding: 18px 48px;
      font-size: 1.25rem;
      font-weight: 600;
      background: var(--accent);
      color: #000;
      border: none;
      border-radius: 50px;
      cursor: pointer;
      transition: all 0.4s ease;
      box-shadow: 0 10px 30px rgba(0, 255, 157, 0.4);
    }

    .cta-button:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 45px rgba(0, 255, 157, 0.5);
    }

    /* Theme Toggle */
    .theme-toggle {
      position: absolute;
      top: 30px;
      right: 30px;
      background: rgba(255,255,255,0.1);
      border: 2px solid var(--accent);
      width: 62px;
      height: 32px;
      border-radius: 50px;
      cursor: pointer;
      display: flex;
      align-items: center;
      padding: 4px;
      transition: all 0.4s ease;
      z-index: 10;
    }

    .theme-toggle::after {
      content: '';
      width: 24px;
      height: 24px;
      background: white;
      border-radius: 50%;
      transition: transform 0.4s ease;
    }

    [data-theme="light"] .theme-toggle {
      background: #333;
    }

    [data-theme="light"] .theme-toggle::after {
      transform: translateX(30px);
    }

    /* Car Animation */
    .car {
      position: absolute;
      bottom: 18%;
      left: -120px;
      font-size: 4.5rem;
      animation: drive 14s linear infinite;
      opacity: 0.12;
      z-index: 1;
    }

    @keyframes drive {
      0% { left: -120px; }
      100% { left: 120vw; }
    }
  </style>
</head>

<body data-theme="dark">
  <div class="background"></div>
  <div class="road"></div>
  <div class="car">🚗</div>

  <div class="container">
    <div class="content">
      <h1 class="logo">BOSSIE RIDE</h1>
      <p class="tagline">Ride smarter.<br>Arrive faster.<br>Your city, your ride.</p>
      
      <button class="cta-button" onclick="window.location.href = '/home'">
        Get a Ride Now
      </button>

      <p style="margin-top: 40px; opacity: 0.75; font-size: 1rem;">
        Available in Nairobi • Safe • Reliable • Affordable
      </p>
    </div>
  </div>

  <script>
    // Safe localStorage to prevent SecurityError in sandboxed environments
    const safeGetItem = (key: string): string | null => {
      try {
        return localStorage.getItem(key);
      } catch {
        return null;
      }
    };

    const safeSetItem = (key: string, value: string): void => {
      try {
        localStorage.setItem(key, value);
      } catch {
        // Silently fail in restricted environments
      }
    };

    const toggleTheme = (): void => {
      const body = document.body;
      const current = body.getAttribute('data-theme') as 'dark' | 'light' || 'dark';
      const next = current === 'dark' ? 'light' : 'dark';
      
      body.setAttribute('data-theme', next);
      safeSetItem('theme', next);
    };

    const loadSavedTheme = (): void => {
      const saved = safeGetItem('theme');
      if (saved === 'dark' || saved === 'light') {
        document.body.setAttribute('data-theme', saved);
      }
    };

    const goToRiderDashboard = (): void => {
      window.location.href = '/rider.html';
    };

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
      loadSavedTheme();
    });
  </script>
</body>
</html>