---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AppHeader from '@/components/common/AppHeader.tsx'
import AppBottomNav from '@/components/common/AppBottomNav.tsx'
import ProfileContent from '@/components/profile/ProfileContent.tsx'
---

<BaseLayout title="Profile - Bossie Ride">
  <AppHeader title="Your Profile" showNotifications={false} />

  <main class="pb-20">
    <ProfileContent client:load />
  </main>

  <AppBottomNav client:idle activeItem="profile" />
</BaseLayout>
