---
import BaseLayout from '@/layouts/BaseLayout.astro'
import AppHeader from '@/components/common/AppHeader.tsx'
import LoginForm from '@/components/auth/LoginForm.tsx' 
---

<BaseLayout 
  title="Log In - Bossie Ride" 
  description="Sign in with Google, Apple, phone number, or email to request rides in Nairobi and beyond."
  theme="dark"
>
  <div class="min-h-dvh bg-background text-foreground flex flex-col">
    <AppHeader title="Log In" showNotifications={false} />

    <main class="flex-1 flex items-center justify-center px-4 py-12">
      <div class="w-full max-w-md">
        <div class="bg-card rounded-3xl shadow-card border border-border overflow-hidden">
          <div class="p-8 md:p-10 space-y-8">
            <div class="text-center space-y-2">
              <h1 class="text-3xl font-bold tracking-tight text-foreground">
                Welcome back to Bossie Ride
              </h1>
              <p class="text-muted-foreground">
                Sign in to request rides, view history & pay with M-Pesa
              </p>
            </div>

            <!-- Social & Phone Login Buttons -->
            <div class="space-y-4">
              <!-- Google Sign In -->
              <button 
                type="button" 
                class="w-full flex items-center justify-center gap-3 rounded-xl border border-border bg-white py-3.5 text-sm font-medium hover:bg-muted transition-colors shadow-sm"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.51h5.84c-.25 1.31-.98 2.42-2.07 3.16v2.63h3.35c1.96-1.81 3.09-4.47 3.09-7.25z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-1.01 7.28-2.73l-3.35-2.63c-1.01.68-2.29 1.08-3.93 1.08-3.02 0-5.58-2.04-6.49-4.79H.96v2.67C2.77 20.39 6.62 23 12 23z"/><path fill="#FBBC05" d="M5.51 14.21c-.23-.68-.36-1.41-.36-2.21s.13-1.53.36-2.21V7.34H.96C.35 8.85 0 10.39 0 12s.35 3.15.96 4.66l4.55-2.45z"/><path fill="#EA4335" d="M12 4.98c1.64 0 3.11.56 4.27 1.66l3.19-3.19C17.46 1.01 14.97 0 12 0 6.62 0 2.77 2.61.96 6.34l4.55 2.45C6.42 6.02 8.98 4.98 12 4.98z"/></svg>
                Continue with Google
              </button>

              <!-- Apple Sign In (show on iOS or always with fallback) -->
              <button 
                type="button" 
                class="w-full flex items-center justify-center gap-3 rounded-xl border border-border bg-white py-3.5 text-sm font-medium hover:bg-muted transition-colors shadow-sm"
              >
                <svg class="h-5 w-5" viewBox="0 0 24 24" fill="black"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm4.59-12.42L13.5 9.09l1.41 1.41-3.5 3.5-1.41-1.41 3.5-3.5-1.41-1.41 3.09-3.09c.39-.39 1.03-.39 1.42 0l2.12 2.12c.39.39.39 1.03 0 1.42z"/></svg>
                Continue with Apple
              </button>
              <button 
                type="button" 
                class="w-full flex items-center justify-center gap-3 rounded-xl border border-border bg-white py-3.5 text-sm font-medium hover:bg-muted transition-colors shadow-sm"
              >
                <span class="text-xl">📱</span>
                Continue with Phone Number
              </button>
            </div>

            <div class="relative my-6">
              <div class="absolute inset-0 flex items-center">
                <div class="w-full border-t border-border"></div>
              </div>
              <div class="relative flex justify-center text-xs uppercase">
                <span class="bg-white/90 px-4 text-muted-foreground">Or sign in with email</span>
              </div>
            </div>

            <!-- Your existing email/password form -->
            <LoginForm client:load />
            <div class="space-y-4 text-center text-sm">
                <p class="mt-8 text-center text-xs text-muted-foreground">
                 By continuing, you agree to our <a href="./terms" class="hover:underline">Terms</a> and <a href="./privacy" class="hover:underline">Privacy Policy</a>.
              </p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>