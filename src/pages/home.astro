---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Bossie Ride | Request rides 24/7"
  description="Request a ride for now or later with Bossie Ride in Nairobi."
  theme="monster"
>
  <div class="min-h-dvh bg-background text-foreground">

      <header class="sticky top-0 z-50 border-b border-border bg-background/90 backdrop-blur">
        <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
          <!-- Logo -->
          <a href="/ride-request" class="flex items-center gap-2 font-semibold tracking-tight">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-black text-white">B</span>
            <span class="text-lg">Bossie Ride</span>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex md:items-center md:gap-8">
            <nav class="flex items-center gap-6 text-sm font-medium">
              <a href="/ride-request" class="hover:text-primary transition-colors">Ride</a>
              <a href="#" class="hover:text-primary transition-colors">Drive</a>
              <a href="#" class="hover:text-primary transition-colors">Business</a>
              <a href="#" class="hover:text-primary transition-colors">Help</a>
            </nav>
            <div class="flex items-center gap-3 ml-8">
              <a href="/login" class="hidden sm:inline-flex rounded-full px-5 py-2 text-sm font-medium hover:bg-muted transition-colors">
                Sign in
              </a>
              <a href="/signup" class="inline-flex rounded-full bg-primary px-6 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors">
                Sign up
              </a>
            </div>
          </div>

          <!-- Mobile Menu -->
          <div class="md:hidden">
            <input type="checkbox" id="mobile-menu" class="peer hidden" />
            <label for="mobile-menu" class="cursor-pointer block">
              <div class="relative flex h-10 w-10 items-center justify-center">
                <div class="relative h-0.5 w-7 rounded-full bg-black transition-all duration-300 peer-checked:bg-transparent">
                  <span class="absolute left-0 top-[-0.375rem] h-0.5 w-7 rounded-full bg-black transition-all duration-300 peer-checked:top-0 peer-checked:rotate-45"></span>
                  <span class="absolute left-0 bottom-[-0.375rem] h-0.5 w-7 rounded-full bg-black transition-all duration-300 peer-checked:bottom-0 peer-checked:-rotate-45"></span>
                </div>
              </div>
            </label>
            <div class="fixed inset-0 z-40 bg-black/40 backdrop-blur-sm transition-opacity duration-300 peer-checked:opacity-100 opacity-0 pointer-events-none peer-checked:pointer-events-auto">
              <div class="absolute right-0 top-0 h-full w-4/5 max-w-sm bg-background shadow-2xl transition-transform duration-400 ease-in-out translate-x-full peer-checked:translate-x-0">
                <div class="flex flex-col h-full p-6 pt-20">
                  <label for="mobile-menu" class="absolute right-6 top-6 text-3xl font-bold text-gray-400 hover:text-black cursor-pointer">×</label>
                  <nav class="flex flex-col gap-6 text-lg font-medium mt-4">
                    <a href="/ride-request" class="hover:text-primary">Ride</a>
                    <a href="#" class="hover:text-primary">Drive</a>
                    <a href="#" class="hover:text-primary">Business</a>
                    <a href="#" class="hover:text-primary">Help</a>
                  </nav>
                  <div class="mt-10 flex flex-col gap-4 pt-8 border-t border-border">
                    <a href="/login" class="rounded-2xl border border-border px-6 py-3.5 text-center font-medium hover:bg-muted">Sign in</a>
                    <a href="/signup" class="rounded-2xl bg-primary px-6 py-3.5 text-center font-semibold text-primary-foreground hover:bg-primary/90">Sign up</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </header>

      <main>
        <!-- Hero -->
        <section class="mx-auto grid max-w-6xl gap-12 px-6 py-20 lg:grid-cols-2 lg:items-center lg:py-24">
          <div class="space-y-6">
            <h1 class="text-5xl sm:text-6xl font-semibold leading-tight tracking-tight">
              Request a ride<br>for now or later
            </h1>
            <p class="text-lg text-muted-foreground max-w-md">
              Add your trip details, hop in, and go. Fast pickup, clear pricing, and reliable support.
            </p>

            <form class="mt-8 rounded-3xl bg-card p-7 shadow-soft" action="/ride-request">
              <div class="flex items-center justify-between gap-3 mb-5">
                <label class="text-sm font-medium" for="pickup-when">Pickup time</label>
                <select id="pickup-when" name="when" class="h-10 rounded-full border border-input bg-background px-5 text-sm focus:outline-none focus:ring-2 focus:ring-ring">
                  <option value="now" selected>Pickup now</option>
                  <option value="later">Pickup later</option>
                </select>
              </div>

              <div class="space-y-4">
                <input id="pickup" name="pickup" placeholder="Pickup location" class="h-12 w-full rounded-2xl border border-gray-300 bg-white px-5 text-sm outline-none focus:ring-2 focus:ring-emerald-400" required />
                <input id="dropoff" name="dropoff" placeholder="Dropoff location" class="h-12 w-full rounded-2xl border border-gray-300 bg-white px-5 text-sm outline-none focus:ring-2 focus:ring-emerald-400" required />
              </div>

              <div class="mt-7 flex flex-col sm:flex-row gap-4">
                <button type="submit" class="flex-1 h-12 rounded-2xl bg-black text-white font-semibold hover:bg-black/90 transition-all">
                  See prices
                </button>
                <a href="/signup" class="flex-1 h-12 flex items-center justify-center rounded-2xl border border-gray-300 font-medium hover:bg-gray-50 transition-all">
                  Sign up to ride
                </a>
              </div>
            </form>
          </div>

          <!-- Right Visual -->
          <div class="relative">
            <div class="aspect-[4/3] w-full overflow-hidden rounded-3xl border border-border bg-card p-8 shadow-card">
              <div class="flex h-full flex-col justify-between">
                <div class="flex gap-4">
                  <div class="flex-1 rounded-2xl border border-border bg-background/80 p-5 shadow-soft">
                    <p class="font-semibold">Your ride, your way</p>
                    <p class="text-sm text-muted-foreground mt-1">Comfort • Economy • Premium</p>
                  </div>
                  <div class="flex-1 rounded-2xl border border-border bg-background/80 p-5 shadow-soft">
                    <p class="font-semibold">700+ airports</p>
                    <p class="text-sm text-muted-foreground mt-1">Schedule ahead</p>
                  </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                  <div class="rounded-2xl border border-border bg-background/80 p-5 shadow-soft">
                    <p class="font-semibold">Upfront pricing</p>
                    <p class="text-sm text-muted-foreground mt-1">No surprises</p>
                  </div>
                  <div class="rounded-2xl border border-border bg-background/80 p-5 shadow-soft">
                    <p class="font-semibold">Safety tools</p>
                    <p class="text-sm text-muted-foreground mt-1">Trip sharing + SOS</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- App Promotion -->
        <section class="border-t border-border bg-muted/40 py-16">
          <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-8 items-center">
            <div>
              <h2 class="text-3xl font-semibold tracking-tight">Do more in the app</h2>
              <p class="mt-3 text-muted-foreground">Save places, view history, manage payments — all in one place.</p>
            </div>
            <div class="flex justify-end">
              <a href="#" class="inline-flex h-12 items-center px-8 rounded-2xl bg-black text-white font-semibold hover:bg-black/90 transition-all">
                Download the app
              </a>
            </div>
          </div>
        </section>
      </main>

      <footer class="border-t border-border py-12 bg-muted/40">
        <div class="max-w-6xl mx-auto px-6 text-center text-sm text-muted-foreground">
          © {new Date().getFullYear()} Bossie Ride • Nairobi, Kenya
        </div>
      </footer>
    </div>
  </div>
</BaseLayout>
</BaseLayout>